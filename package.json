{
  "name": "express-typescript",
  "version": "1.0.0",
  "description": "",
  "main": "dist/app.js",
  "scripts": {
    "start": "tsc && DEBUG='error:*' node --expose-gc ./dist/index.js",
    "test": "nodemon --exec ts-node --files ./index.ts",
    "dev": "nodemon --exec DEBUG='dev:*,error:*,info:*' ts-node --files ./index.ts",
    "dev:bench": "nodemon --exec DEBUG='dev:*,error:*,info:*,bench:*' ts-node --files ./index.ts",
    "dev:query": "nodemon --exec DEBUG='dev:*,error:*,info:*,query:*' ts-node --files ./index.ts",
    "dev:all": "nodemon --exec DEBUG='dev:*,error:*,info:*,query:*,bench:*' ts-node --files ./index.ts",
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
